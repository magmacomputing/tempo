{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "noEmit": true,
    "composite": true,
    "types": [
      "vitest/globals",
      "node"
    ],
    "paths": {
      "#library": [
        "../../library/src/common.index.ts"
      ],
      "#library/*": [
        "../../library/src/common/*"
      ],
      "#browser/*": [
        "../../library/src/browser/*"
      ],
      "#server/*": [
        "../../library/src/server/*"
      ],
      "#tempo": [
        "../src/tempo.index.ts"
      ],
      "#tempo/core": [
        "../src/core.index.ts"
      ],
      "#tempo/duration": [
        "../src/plugin/module/module.duration.ts"
      ],
      "#tempo/format": [
        "../src/plugin/module/module.format.ts"
      ],
      "#tempo/ticker": [
        "../src/plugin/extend/extend.ticker.ts"
      ],
      "#tempo/term/*": [
        "../src/plugin/term/term.*.ts"
      ],
      "#tempo/*": [
        "../src/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "references": [
    {
      "path": "../src/tsconfig.json"
    }
  ]
}