{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": [
      "vitest/globals",
      "node"
    ],
    "noEmit": true,
    "rootDir": "../../",
    "paths": {
      "#library/*": [
        "../../library/src/*"
      ],
      "#tempo/*": [
        "../src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "../src/**/*.ts",
    "../../library/src/**/*.ts"
  ]
}