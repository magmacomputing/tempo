{
  "name": "@magma/tempo",
  "version": "1.2.0",
  "description": "The Tempo core library",
  "type": "module",
  "main": "dist/tempo.index.js",
  "types": "dist/tempo.index.d.ts",
  "imports": {
    "#library": {
      "development": "../library/src/common/index.js",
      "default": "@magma/library"
    },
    "#library/*": {
      "development": "../library/src/common/*",
      "default": "@magma/library/*"
    },
    "#browser/*": {
      "development": "../library/src/browser/*",
      "default": "@magma/library/browser/*"
    },
    "#server/*": {
      "development": "../library/src/server/*",
      "default": "@magma/library/server/*"
    },
    "#tempo": {
      "development": "./src/tempo.index.ts",
      "default": "./dist/tempo.index.js"
    },
    "#tempo/*.js": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/tempo.index.d.ts",
      "import": "./dist/tempo.index.js"
    },
    "./enums": {
      "types": "./dist/tempo.enum.d.ts",
      "import": "./dist/tempo.enum.js"
    },
    "./plugins/ticker": {
      "types": "./dist/plugins/plugin.ticker.d.ts",
      "import": "./dist/plugins/plugin.ticker.js"
    },
    "./library": {
      "types": "./dist/library.index.d.ts",
      "import": "./dist/library.index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "repl": "tsx -i --import ./bin/setup.ts --import ./bin/repl.ts",
    "build": "tsc -b && npm run build:bundle && bash bin/resolve-self.sh",
    "build:bundle": "rollup -c",
    "clean": "tsc -b --clean",
    "publish": "npm publish --access public",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "dependencies": {
    "@magma/library": "1.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@rollup/plugin-alias": "^6.0.0"
  }
}