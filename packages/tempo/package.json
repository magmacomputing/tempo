{
  "name": "@magmacomputing/tempo",
  "version": "2.0.1",
  "description": "The Tempo core library",
  "author": "Magma Computing Solutions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magmacomputing/magma.git",
    "directory": "packages/tempo"
  },
  "homepage": "https://github.com/magmacomputing/magma/tree/main/packages/tempo#readme",
  "bugs": {
    "url": "https://github.com/magmacomputing/magma/issues"
  },
  "keywords": [
    "temporal",
    "date",
    "time",
    "immutable",
    "fluent",
    "parsing"
  ],
  "type": "module",
  "main": "dist/tempo.index.js",
  "types": "dist/tempo.index.d.ts",
  "imports": {
    "#library": "@magmacomputing/library",
    "#library/*.js": "@magmacomputing/library/common/*.js",
    "#tempo": {
      "development": "./src/tempo.index.ts",
      "default": "./dist/tempo.index.js"
    },
    "#tempo/core": {
      "development": "./src/tempo.core.ts",
      "default": "./dist/tempo.core.js"
    },
    "#tempo/plugins/plugin.*.js": {
      "development": "./src/plugins/plugin.*.ts",
      "default": "./dist/plugins/plugin.*.js"
    },
    "#tempo/plugins/extend.*.js": {
      "development": "./src/plugins/extend/extend.*.ts",
      "default": "./dist/plugins/extend/extend.*.js"
    },
    "#tempo/plugins/module.*.js": {
      "development": "./src/plugins/module/module.*.ts",
      "default": "./dist/plugins/module/module.*.js"
    },
    "#tempo/plugins/term.*.js": {
      "development": "./src/plugins/term/term.*.ts",
      "default": "./dist/plugins/term/term.*.js"
    },
    "#tempo/scripts/*.js": "./scripts/*.ts",
    "#tempo/tempo.class.js": {
      "development": "./src/tempo.index.ts",
      "default": "./dist/tempo.index.js"
    },
    "#tempo/*.js": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/tempo.index.d.ts",
      "import": "./dist/tempo.index.js"
    },
    "./enums": {
      "types": "./dist/tempo.enum.d.ts",
      "import": "./dist/tempo.enum.js"
    },
    "./extend/*": {
      "types": "./dist/plugins/extend/extend.*.d.ts",
      "import": "./dist/plugins/extend/extend.*.js"
    },
    "./module/*": {
      "types": "./dist/plugins/module/module.*.d.ts",
      "import": "./dist/plugins/module/module.*.js"
    },
    "./term/*": {
      "types": "./dist/plugins/term/term.*.d.ts",
      "import": "./dist/plugins/term/term.*.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js"
    },
    "./ticker": {
      "types": "./dist/plugins/extend/extend.ticker.d.ts",
      "import": "./dist/plugins/extend/extend.ticker.js"
    },
    "./duration": {
      "types": "./dist/plugins/module/module.duration.d.ts",
      "import": "./dist/plugins/module/module.duration.js"
    },
    "./format": {
      "types": "./dist/plugins/module/module.format.d.ts",
      "import": "./dist/plugins/module/module.format.js"
    },
    "./library": {
      "types": "./dist/library.index.d.ts",
      "import": "./dist/library.index.js"
    },
    "./core": {
      "types": "./dist/tempo.core.d.ts",
      "import": "./dist/tempo.core.js"
    }
  },
  "scripts": {
    "test": "vitest run --workspace ../../vitest.workspace.ts",
    "repl": "tsx --conditions=development -i --import ./scripts/setup.full.ts --import ./scripts/repl.ts",
    "core": "tsx --conditions=development -i --import ./scripts/setup.core.ts --import ./scripts/core.ts",
    "build": "tsc -b && npm run build:bundle && npm run build:resolve",
    "build:bundle": "rollup -c",
    "build:resolve": "tsx scripts/resolve-types.ts",
    "clean": "tsc -b --clean && rm -rf dist",
    "publish": "npm publish --access public",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "doc/",
    "dist/",
    "src/"
  ],
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@magmacomputing/library": "2.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "magic-string": "^0.30.21"
  },
  "directories": {
    "doc": "doc",
    "test": "test"
  }
}