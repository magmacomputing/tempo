{
  "name": "@magma/tempo",
  "version": "1.2.0",
  "description": "The Tempo core library",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#library/*": {
      "development": "../library/src/*",
      "default": "@magma/library/*"
    },
    "#tempo/*": {
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./enums": {
      "types": "./dist/tempo.config/tempo.enum.d.ts",
      "import": "./dist/tempo.config/tempo.enum.js"
    },
    "./plugins/ticker": {
      "types": "./dist/tempo.config/plugins/plugin.ticker.d.ts",
      "import": "./dist/tempo.config/plugins/plugin.ticker.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "repl": "tsx -i --import ./test/repl.ts",
    "build": "tsc -b && npm run build:bundle",
    "build:bundle": "rollup -c",
    "clean": "tsc -b --clean",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "dependencies": {
    "@magma/library": "1.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0"
  }
}
