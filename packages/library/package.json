{
  "name": "@magma/library",
  "version": "1.2.0",
  "description": "Shared utility library for Tempo",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "imports": {
    "#library/*": {
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
