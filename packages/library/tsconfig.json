{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "paths": {
      "#library": [
        "./src/common/index.ts"
      ],
      "#library/*": [
        "./src/common/*"
      ],
      "#browser/*": [
        "./src/browser/*"
      ],
      "#server/*": [
        "./src/server/*"
      ],
      "#tempo": [
        "../tempo/src/tempo.index.ts"
      ],
      "#tempo/*": [
        "../tempo/src/*"
      ]
    }
  },
  "files": [],
  "references": [
    {
      "path": "./src"
    }
  ]
}